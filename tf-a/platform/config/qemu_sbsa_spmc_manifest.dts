 /dts-v1/;
 / {
   compatible = "arm,ffa-core-manifest-1.0";
   #address-cells = <2>;
   #size-cells = <2>;
   attribute {
     spmc_id = <0x8000>;
     maj_ver = <0x1>;
     min_ver = <0x1>;
     exec_state = <0x0>;
     load_address = <0x0 0x30000000>;
     entrypoint = <0x0 0x30000000>;
     binary_size = <0x80000>;
   };

   hypervisor {
     compatible = "hafnium,hafnium";
     vm1 {
       is_ffa_partition;
       debug_name = "ec-sp";
       load_address = <0x0 0x20002000>;
       vcpu_count = <1>;
       mem_size = <0x0 0x300000>;
     };
   };

   cpus {
     #address-cells = <0x2>;
     #size-cells = <0x0>;
    cpu@0 {
      device_type = "cpu";
      reg = <0x0 0x0>;
    };
    cpu@3 {
      device_type = "cpu";
      reg = <0x0 0x3>;
    };
  cpu@2 {
   device_type = "cpu";
   reg = <0x0 0x2>;
  };
  cpu@1 {
   device_type = "cpu";
   reg = <0x0 0x1>;
  };
   };
  memory@0 {
    device_type = "memory";
    reg = <0x0 0x20000000 0x0 0x20000000>;
  };
  memory@1 {
  device_type = "device-memory";
  reg = <0x0 0x60000000 0x0 0x00001000>;
 };
  memory@3 {
  device_type = "device-memory";
  reg = <0x0 0x60040000 0x0 0x00001000>;
 };
  memory@4 {
  device_type = "device-memory";
  reg = <0x0 0x01000000 0x0 0x000C0000>;
 };
  memory@5 {
  device_type = "device-memory";
  reg = <0x0 0x60030000 0x0 0x00001000>;
 };
  memory@6 {
  device_type = "device-memory";
  reg = <0x00000100 0x1FFFE000 0x0 0x00001000>;
 };
  memory@2 {
    device_type = "ns-memory";
    reg = <0x00000100 0x00000000 0x0 0x80000000>;
  };
  memory@8 {
    device_type = "device-memory";
    reg = <0x00000100 0x00200000 0x0 0x00010000>;
  };
  memory@9 {
    device_type = "device-memory";
    reg = <0x00000000 0x60120000 0x0 0x00010000>;
  };
  memory@10 {
    device_type = "memory";
    reg = <0x00000100 0x60000000 0x0 0x00002000>;
  };
  memory@11 {
    device_type = "memory";
    reg = <0x00000100 0x600A0000 0x0 0x00002000>;
  };
  memory@12 {
    device_type = "device-memory";
    reg = <0x0 0x60200000 0x0 0x00001000>;
 };
};
